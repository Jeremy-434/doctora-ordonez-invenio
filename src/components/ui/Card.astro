---
interface Props {
  title: string;
  body: string;
  icon?: string;
  topAccent?: boolean; // Kept for interface compatibility but ignored
}

const { title, body, icon } = Astro.props;
---

<div
  class="bg-surface border border-border-light hover:border-border transition-colors duration-300 p-8 h-full flex flex-col"
  data-animate="service-card"
>
  {
    icon && (
      <div class="text-4xl mb-6 font-display text-text-faint">
        {icon}
      </div>
    )
  }
  <h3 class="text-xl font-display font-semibold text-text mb-4 mt-auto">{title}</h3>
  <p class="text-text-muted leading-relaxed">{body}</p>
</div>
