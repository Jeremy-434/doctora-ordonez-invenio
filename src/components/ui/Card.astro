---
interface Props {
  title: string;
  body: string;
  icon?: string;
  topAccent?: boolean;
}

const { title, body, icon, topAccent = false } = Astro.props;
---

<div
  class={`bg-surface rounded-xl shadow-sm hover:shadow-md transition p-6 ${topAccent ? 'border-t-4 border-primary' : ''}`}
  data-animate="service-card"
  data-card
>
  {
    icon && (
      <div class="text-4xl mb-4">
        {icon}
      </div>
    )
  }
  <h3 class="text-xl font-semibold text-text mb-3">{title}</h3>
  <p class="text-text-muted leading-relaxed">{body}</p>
</div>

<style>
  @media (hover: hover) {
    [data-card] {
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    [data-card]:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-md);
    }
  }
</style>
