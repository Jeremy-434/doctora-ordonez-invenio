---
interface Props {
  title: string;
  body: string;
  icon?: string;
  topAccent?: boolean;
}

const { title, body, icon, topAccent = false } = Astro.props;
---

<div
  class={`bg-white rounded-xl shadow-sm hover:shadow-md transition p-6 ${topAccent ? 'border-t-4 border-secondary' : ''}`}
>
  {
    icon && (
      <div class="text-4xl mb-4">
        {icon}
      </div>
    )
  }
  <h3 class="text-xl font-semibold text-text mb-3">{title}</h3>
  <p class="text-gray-600 leading-relaxed">{body}</p>
</div>
