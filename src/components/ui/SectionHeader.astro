---
type Alignment = 'left' | 'center';

interface Props {
  title: string;
  subtitle?: string;
  align?: Alignment;
}

const { title, subtitle, align = 'center' } = Astro.props;
---

<div class={`mb-16 ${align === 'center' ? 'text-center' : ''}`}>
  {
    subtitle && (
      <div class="overflow-hidden mb-6">
        <p class="label-caps text-text-muted" data-animate="section-subtitle">
          {subtitle}
        </p>
      </div>
    )
  }
  <div class="overflow-hidden">
    <h2 class="font-display text-4xl md:text-5xl lg:text-6xl text-text tracking-tight" data-animate="section-title">{title}</h2>
  </div>
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReduced) {
    document.querySelectorAll('[data-animate="section-title"]').forEach(el => {
      gsap.from(el, {
        clipPath: 'inset(100% 0 0 0)',
        y: 40,
        opacity: 0,
        duration: 1.2,
        ease: 'power3.out',
        scrollTrigger: { trigger: el, start: 'top 85%', once: true },
      });
    });

    document.querySelectorAll('[data-animate="section-subtitle"]').forEach(el => {
      gsap.from(el, {
        opacity: 0,
        duration: 0.8,
        delay: 0.2,
        scrollTrigger: { trigger: el, start: 'top 85%', once: true },
      });
    });
  }
</script>
