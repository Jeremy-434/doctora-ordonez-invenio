---
type Alignment = 'left' | 'center';

interface Props {
  title: string;
  subtitle?: string;
  align?: Alignment;
}

const { title, subtitle, align = 'center' } = Astro.props;
---

<div class={`mb-12 ${align === 'center' ? 'text-center' : ''}`}>
  <h2 class="text-2xl md:text-4xl font-bold text-primary mb-4">{title}</h2>
  {
    subtitle && (
      <p class="text-gray-600 text-lg max-w-2xl mx-auto">
        {subtitle}
      </p>
    )
  }
</div>
