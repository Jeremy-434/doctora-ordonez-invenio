---
interface Props {
  logo: string;
  tagline: string;
  navLinks: string[];
  copyright: string;
}

const { logo, tagline, navLinks, copyright } = Astro.props;
---

<footer class="bg-surface text-text py-16 md:py-24">
  <div class="px-4 md:px-8 lg:px-16 xl:px-24 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <div>
        <img src={logo} alt="Unifisio" class="h-8 brightness-0 invert mb-4" />
        <p class="text-text-muted">{tagline}</p>
      </div>

      <div>
        <h4 class="font-semibold mb-4">Navegación</h4>
        <ul class="space-y-2">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link === 'Servicios' ? '#servicios' : link === 'Proceso' ? '#proceso' : link === 'Testimonios' ? '#testimonios' : '#calendar'}
                  class="text-text-muted hover:text-primary transition"
                >
                  {link}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4 class="font-semibold mb-4">Contacto</h4>
        <div class="flex gap-4">
          <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-primary transition" aria-label="Instagram">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.057-1.645.069-4.849.069-3.204 0-3.584-.012-4.849-.069-3.259-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zM5.838 12a6.162 6.162 0 1 1 12.324 0 6.162 6.162 0 0 1-12.324 0zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm4.965-10.322a1.44 1.44 0 1 1 2.881.001 1.44 1.44 0 0 1-2.881-.001z" />
            </svg>
          </a>
          <a href="#" class="text-text-muted hover:text-primary transition" aria-label="WhatsApp">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.67-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.076 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421-7.403h-.004a9.87 9.87 0 00-9.746 9.798c0 2.734.75 5.413 2.174 7.72l-2.308 8.415 8.616-2.262c2.25 1.231 4.788 1.899 7.422 1.899 5.409 0 9.847-4.411 9.847-9.846 0-2.605-.994-5.071-2.787-6.932a9.825 9.825 0 00-7.214-2.992z" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-border pt-8 text-center text-text-faint text-sm">
      {copyright}
    </div>
  </div>
</footer>

<style>
  a:focus {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>
