---
import SectionHeader from '../ui/SectionHeader.astro';

interface Props {
  calendarId: string;
  baseUrl: string;
}

const { calendarId, baseUrl } = Astro.props;
const iframeSrc = `${baseUrl}${calendarId}`;
const iframeId = `${calendarId}_1781905181748`;
---

<section id="calendar" class="bg-surface py-24 md:py-32 border-t border-border">
  <div class="px-4 md:px-8 lg:px-16 xl:px-24 max-w-7xl mx-auto">
    <SectionHeader title="Agenda tu cita online" align="center" />

    <div class="mt-16 bg-bg border border-border-light overflow-hidden" data-animate="calendar-iframe">
      <iframe
        src={iframeSrc}
        style="width: 100%; border:none; overflow: hidden;"
        scrolling="no"
        id={iframeId}
        title="Calendario de Agendamiento"
      ></iframe>
      <script is:inline src="https://www.invenioagency.com/js/form_embed.js" type="text/javascript"></script>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReduced) {
    gsap.from('[data-animate="calendar-iframe"]', {
      opacity: 0,
      y: 30,
      duration: 1,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '#calendar',
        start: 'top 85%',
        once: true,
      },
    });
  }
</script>
