---
import SectionHeader from '../ui/SectionHeader.astro';

interface ProcessStep {
  number: string;
  title: string;
  description: string;
}

interface Props {
  title: string;
  subtitle: string;
  steps: ProcessStep[];
}

const { title, subtitle, steps } = Astro.props;
---

<section id="proceso" class="bg-surface py-24 md:py-32 border-t border-border">
  <div class="px-4 md:px-8 lg:px-16 xl:px-24 max-w-7xl mx-auto">
    <SectionHeader title={title} subtitle={subtitle} align="left" />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 border-t border-border mt-16 pt-16 gap-8 relative">
      {
        steps.map((step, index) => (
          <div class="relative group" data-animate="step">
            <div class="font-display text-text-faint text-6xl md:text-7xl mb-8 leading-none">{step.number}</div>
            <h3 class="text-xl font-display font-semibold text-text mb-4">{step.title}</h3>
            <p class="text-sm text-text-muted leading-relaxed">{step.description}</p>

            {index < steps.length - 1 && (
              <div class="hidden lg:block absolute top-10 -right-4 w-8 h-[1px] bg-border" data-animate="process-line"></div>
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReduced) {
    gsap.from('[data-animate="process-line"]', {
      scaleX: 0,
      transformOrigin: 'left center',
      duration: 1.2,
      ease: 'power3.inOut',
      scrollTrigger: { trigger: '#proceso', start: 'top 70%', once: true },
    });

    gsap.from('[data-animate="step"]', {
      x: -30, opacity: 0, duration: 0.8,
      stagger: 0.2,
      ease: 'power2.out',
      scrollTrigger: { trigger: '#proceso', start: 'top 75%', once: true },
    });
  }
</script>
