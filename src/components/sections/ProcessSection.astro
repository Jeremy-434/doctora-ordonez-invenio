---
import SectionHeader from '../ui/SectionHeader.astro';

interface ProcessStep {
  number: string;
  title: string;
  description: string;
}

interface Props {
  title: string;
  subtitle: string;
  steps: ProcessStep[];
}

const { title, subtitle, steps } = Astro.props;
---

<section id="proceso" class="bg-accent-light py-16 md:py-24">
  <div class="px-4 md:px-8 lg:px-16 xl:px-24 max-w-7xl mx-auto">
    <SectionHeader title={title} subtitle={subtitle} align="center" />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 relative">
      {
        steps.map((step, index) => (
          <div class="relative">
            <div class="text-6xl font-bold text-secondary mb-4">{step.number}</div>
            <h3 class="text-2xl font-semibold text-primary mb-3">{step.title}</h3>
            <p class="text-gray-700 leading-relaxed">{step.description}</p>

            {index < steps.length - 1 && (
              <div class="hidden md:block absolute top-12 -right-6 w-12 h-1 bg-secondary"></div>
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>
