---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

<section class="bg-primary text-white py-16 md:py-24">
  <div class="px-4 md:px-8 lg:px-16 xl:px-24 max-w-7xl mx-auto">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12">
      {
        stats.map((stat) => (
          <div class="text-center">
            <div class="text-3xl md:text-5xl font-bold mb-2">{stat.value}</div>
            <p class="text-white/80 text-sm md:text-base">{stat.label}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
