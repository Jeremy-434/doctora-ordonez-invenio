---
import Button from '../ui/Button.astro';

interface Props {
  educational: {
    title: string;
    subtitle: string;
    youtubeLink: string;
    videoUrl: string;
  };
}

const { educational } = Astro.props;
const { title, subtitle, youtubeLink, videoUrl } = educational;
---

<section class="border-y border-border bg-surface py-24 md:py-32">
  <div class="max-w-7xl mx-auto px-4 md:px-8 lg:px-16 xl:px-24">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      
      <div data-animate="edu-text">
        <div class="label-caps text-text-muted mb-8">Contenido de Valor</div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-display text-text leading-tight mb-8">
          {title}
        </h2>
        <p class="text-lg text-text-muted mb-12">
          {subtitle}
        </p>
        <Button variant="primary" text="Ver canal de YouTube" onClick={`window.open('${youtubeLink}', '_blank')`} />
      </div>

      <div class="aspect-video bg-bg border border-border relative overflow-hidden" data-animate="edu-video">
        <video
          src={videoUrl}
          poster="/infra-1.jpeg"
          controls
          preload="none"
          class="w-full h-full object-cover"
          aria-label="Video psicoeducativo de Fernando Bonilla"
        ></video>
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReduced) {
    gsap.from('[data-animate="edu-text"]', {
      x: -30, opacity: 0, duration: 1, ease: 'power2.out',
      scrollTrigger: { trigger: '[data-animate="edu-text"]', start: 'top 85%', once: true },
    });
    gsap.from('[data-animate="edu-video"]', {
      x: 30, opacity: 0, duration: 1, ease: 'power2.out', delay: 0.2,
      scrollTrigger: { trigger: '[data-animate="edu-video"]', start: 'top 85%', once: true },
    });
  }
</script>
