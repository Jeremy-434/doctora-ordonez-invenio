---
import Button from '../ui/Button.astro';
import MobileNav from '../layout/MobileNav';

interface Props {
  name: string;
  navLinks: string[];
}

const { name, navLinks } = Astro.props;
---

<header class="sticky top-0 z-50 bg-bg border-b border-border">
  <nav class="flex items-center justify-between px-4 md:px-8 lg:px-16 xl:px-24 py-4">

    <a href="#" class="flex items-center no-underline" aria-label="Inicio">
      <span class="font-display text-text text-xl leading-none tracking-tight">{name}</span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      {
        navLinks.map((link) => {
          let id = '#';
          if (link.toLowerCase().includes('especialidad')) id = '#servicios';
          else if (link.toLowerCase().includes('proceso')) id = '#proceso';
          else if (link.toLowerCase().includes('sobre')) id = '#equipo';
          else if (link.toLowerCase().includes('reseña')) id = '#testimonios';
          else if (link.toLowerCase().includes('ubic')) id = '#visitanos';

          return (
            <a
              href={id}
              class="text-text font-medium hover:text-text-muted transition-colors label-caps"
            >
              {link}
            </a>
          );
        })
      }
    </div>

    <div class="hidden md:flex items-center gap-4">
      <Button
        variant="ghost"
        size="sm"
        text="Agendar"
        onClick="document.getElementById('calendar')?.scrollIntoView({behavior:'smooth'})"
      />
    </div>

    <div class="md:hidden">
      <MobileNav client:only="react" navLinks={navLinks} />
    </div>

  </nav>
</header>

<style>
  a:focus {
    outline: 2px solid var(--color-border);
    outline-offset: 4px;
  }

  @media (hover: hover) {
    nav a {
      position: relative;
    }
    nav a::after {
      content: '';
      position: absolute;
      left: 0;
      bottom: -4px;
      width: 100%;
      height: 1px;
      background: var(--color-text);
      transform: scaleX(0);
      transform-origin: right;
      transition: transform 0.3s ease;
    }
    nav a:hover::after {
      transform: scaleX(1);
      transform-origin: left;
    }
  }
</style>
