---
import SectionHeader from '../ui/SectionHeader.astro';

interface Props {
  contact: {
    title: string;
    location: string;
    mapUrl: string;
    videoUrl: string;
    reasons: string[];
  };
}

const { contact } = Astro.props;
---

<section id="visitanos" class="bg-bg py-24 md:py-32 border-t border-border">
  <div class="px-4 md:px-8 lg:px-16 xl:px-24 max-w-7xl mx-auto">
    <SectionHeader title={contact.title} align="left" />

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 border-l border-t border-border-light mt-16">
      
      {/* Map Column */}
      <div class="border-r border-b border-border-light flex flex-col h-full" data-animate="contact-item">
        <div class="p-8 md:p-10 border-b border-border-light">
          <h3 class="font-display text-2xl text-text mb-2">Nuestra Ubicación</h3>
          <p class="text-text-muted">{contact.location}</p>
        </div>
        <div class="aspect-video w-full bg-surface relative flex-grow min-h-[300px]">
          <iframe 
            src={contact.mapUrl} 
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade"
            class="absolute inset-0 grayscale contrast-125 opacity-80"
          ></iframe>
        </div>
      </div>

      {/* Video Column */}
      <div class="bg-surface border-r border-b border-border-light flex flex-col h-full" data-animate="contact-item">
        <div class="p-8 md:p-10 border-b border-border-light">
          <h3 class="font-display text-2xl text-text mb-2">¿Cómo llegar?</h3>
          <p class="text-text-muted">Mira nuestro video guía para encontrar la entrada fácilmente.</p>
        </div>
        <div class="w-full flex-grow relative overflow-hidden flex items-center justify-center min-h-[300px]">
           <!-- Placeholder for video -->
          <div class="absolute inset-0 flex items-center justify-center bg-bg">
            <div class="w-16 h-16 rounded-full bg-text flex items-center justify-center pl-1 cursor-pointer hover:scale-110 transition-transform">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M8 5V19L19 12L8 5Z" fill="var(--color-bg)"/>
              </svg>
            </div>
          </div>
          <p class="absolute bottom-6 text-sm text-text-faint font-display">Ver video guía</p>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReduced) {
    gsap.from('[data-animate="contact-item"]', {
      opacity: 0,
      y: 20,
      duration: 0.8,
      stagger: 0.2,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '#visitanos .grid',
        start: 'top 85%',
        once: true,
      },
    });
  }
</script>
