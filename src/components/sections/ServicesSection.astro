---
import SectionHeader from '../ui/SectionHeader.astro';
import Card from '../ui/Card.astro';

interface Service {
  title: string;
  icon: string;
  description: string;
}

interface Props {
  title: string;
  subtitle: string;
  services: Service[];
}

const { title, subtitle, services } = Astro.props;
---

<section id="servicios" class="bg-bg py-24 md:py-32">
  <div class="px-4 md:px-8 lg:px-16 xl:px-24 max-w-7xl mx-auto">
    <SectionHeader title={title} subtitle={subtitle} align="center" />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-0 border-l border-t border-border-light">
      {
        services.map((service, index) => (
          <div class="border-r border-b border-border-light">
            <Card title={service.title} body={service.description} icon={String(index + 1).padStart(2, '0')} />
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReduced) {
    gsap.from('[data-animate="service-card"]', {
      opacity: 0, duration: 0.8,
      stagger: { amount: 0.4, from: 'start' },
      scrollTrigger: {
        trigger: '#servicios .grid',
        start: 'top 85%',
        once: true,
      },
    });
  }
</script>
