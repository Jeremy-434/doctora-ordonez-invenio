---
import SectionHeader from '../ui/SectionHeader.astro';
import Card from '../ui/Card.astro';
import Button from '../ui/Button.astro';

interface Props {
  services: {
    title: string;
    items: Array<{
      title: string;
      icon: string;
      description: string;
    }>;
    cta: string;
  };
}

const { services } = Astro.props;
---

<section id="servicios" class="bg-bg py-24 md:py-32">
  <div class="px-4 md:px-8 lg:px-16 xl:px-24 max-w-7xl mx-auto">
    <SectionHeader title={services.title} align="left" />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-0 border-l border-t border-border-light mt-12">
      {
        services.items.map((service, index) => (
          <div class="border-r border-b border-border-light">
            <Card title={service.title} body={service.description} icon={service.icon} />
          </div>
        ))
      }
    </div>

    <div class="mt-16 pt-8 border-t border-border-light flex flex-col md:flex-row items-center justify-between gap-8">
      <p class="text-xl text-text-muted font-display italic">
        {services.cta}
      </p>
      <Button variant="primary" text="Agendar" onClick="document.getElementById('calendar')?.scrollIntoView({behavior:'smooth'})" />
    </div>
  </div>
</section>


<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReduced) {
    gsap.from('[data-animate="service-card"]', {
      opacity: 0, duration: 0.8,
      stagger: { amount: 0.4, from: 'start' },
      scrollTrigger: {
        trigger: '#servicios .grid',
        start: 'top 85%',
        once: true,
      },
    });
  }
</script>
