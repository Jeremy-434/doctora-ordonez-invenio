---
import Button from '../ui/Button.astro';

interface Props {
  headline: string;
  subtext: string;
  buttonText: string;
  whatsapp: string;
}

const { headline, subtext, buttonText, whatsapp } = Astro.props;
---

<section class="py-16 md:py-24 text-text border-y border-primary/20" style="background: linear-gradient(135deg, var(--color-surface) 0%, var(--color-bg) 100%);">
  <div class="px-4 md:px-8 lg:px-16 xl:px-24 max-w-4xl mx-auto text-center">
    <h2 class="text-3xl md:text-5xl font-bold mb-4" data-animate="cta-headline">{headline}</h2>
    <p class="text-lg text-text-muted mb-8">{subtext}</p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-6">
      <Button variant="secondary" size="lg" text={buttonText} onClick="document.getElementById('calendar')?.scrollIntoView({behavior:'smooth'})" data-magnetic />
    </div>

    <p class="text-text-faint">
      O escribinos por
      <a href={`https://wa.me/${whatsapp.replace(/\D/g, '')}`} target="_blank" rel="noopener noreferrer" class="text-primary font-semibold hover:underline ml-1">
        WhatsApp
      </a>
    </p>
  </div>
</section>

<style>
  a:focus {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);
  import { splitAndReveal } from '@/lib/animations';

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const el = document.querySelector('[data-animate="cta-headline"]');
  if (el && !prefersReduced) {
    splitAndReveal(el, { delay: 0.1 });
  }
</script>
