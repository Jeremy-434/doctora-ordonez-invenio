---
import Button from '../ui/Button.astro';

interface Props {
  headline: string;
  subtext: string;
  buttonText: string;
  whatsapp: string;
}

const { headline, subtext, buttonText, whatsapp } = Astro.props;
---

<section class="bg-primary text-white py-16 md:py-24">
  <div class="px-4 md:px-8 lg:px-16 xl:px-24 max-w-4xl mx-auto text-center">
    <h2 class="text-3xl md:text-5xl font-bold mb-4">{headline}</h2>
    <p class="text-lg text-white/80 mb-8">{subtext}</p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-6">
      <Button variant="secondary" size="lg" text={buttonText} onClick="document.getElementById('calendar')?.scrollIntoView({behavior:'smooth'})" />
    </div>

    <p class="text-white/70">
      O escribinos por
      <a href={`https://wa.me/${whatsapp.replace(/\D/g, '')}`} target="_blank" rel="noopener noreferrer" class="text-white font-semibold hover:underline ml-1">
        WhatsApp
      </a>
    </p>
  </div>
</section>

<style>
  a:focus {
    outline: 2px solid white;
    outline-offset: 2px;
  }
</style>
