---
import SectionHeader from '../ui/SectionHeader.astro';
import ExpandableText from '../ui/ExpandableText';

interface Props {
  team: {
    title: string;
    members: Array<{
      name: string;
      role: string;
      description: string;
      image: string;
    }>;
  };
}

const { team } = Astro.props;
---

<section id="equipo" class="bg-bg py-24 md:py-32 border-t border-border">
  <div class="px-4 md:px-8 lg:px-16 xl:px-24 max-w-7xl mx-auto">
    <SectionHeader title={team.title} align="left" />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-0 border-l border-t border-border-light mt-16">
      {
        team.members.map((member) => (
          <div class="border-r border-b border-border-light flex flex-col sm:flex-row group" data-animate="team-card">
            <div class="w-full sm:w-1/3 aspect-square sm:aspect-auto bg-surface relative overflow-hidden border-b sm:border-b-0 sm:border-r border-border-light">
              <img
                src={member.image}
                alt={member.name}
                class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="w-full sm:w-2/3 p-8 md:p-10 flex flex-col justify-center">
              <h3 class="font-display text-2xl text-text mb-2">{member.name}</h3>
              <p class="label-caps text-text-muted mb-6">{member.role}</p>
              <ExpandableText client:only="react" text={member.description} maxLines={3} />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReduced) {
    gsap.from('[data-animate="team-card"]', {
      opacity: 0,
      y: 20,
      duration: 0.8,
      stagger: 0.2,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '#equipo .grid',
        start: 'top 85%',
        once: true,
      },
    });
  }
</script>
