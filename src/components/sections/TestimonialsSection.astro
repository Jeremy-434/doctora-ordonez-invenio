---
import SectionHeader from '../ui/SectionHeader.astro';
import StarRating from '../ui/StarRating.astro';

interface Testimonial {
  quote: string;
  author: string;
  role: string;
  stars: number;
}

interface Props {
  title: string;
  testimonials: Testimonial[];
}

const { title, testimonials } = Astro.props;
---

<section id="testimonios" class="bg-white py-16 md:py-24">
  <div class="px-4 md:px-8 lg:px-16 xl:px-24 max-w-7xl mx-auto">
    <SectionHeader title={title} align="center" />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        testimonials.map((testimonial) => (
          <div class="bg-white border-l-4 border-secondary rounded-xl shadow-sm p-8">
            <div class="mb-4">
              <svg class="w-8 h-8 text-secondary mb-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M3 21c3 0 7-1 7-8V5c0-1.25-4.45-5-7-5m14 0c-3.55 0-7 3.75-7 5v8c0 7 4 8 7 8s4-2 4-4v-3c1 1 3 2 5 2v-3c-1-1-3-1-5-2V5c0-1.75 0-4 2.5-4s2.5 2.5 2.5 4v8c0 7-4 8-7 8z" />
              </svg>
            </div>

            <p class="text-gray-700 mb-6 italic leading-relaxed">"{testimonial.quote}"</p>

            <StarRating count={testimonial.stars} />

            <div class="mt-6">
              <p class="font-semibold text-primary">{testimonial.author}</p>
              <p class="text-sm text-gray-600">{testimonial.role}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
