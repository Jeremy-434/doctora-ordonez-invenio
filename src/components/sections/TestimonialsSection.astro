---
import SectionHeader from '../ui/SectionHeader.astro';
import StarRating from '../ui/StarRating.astro';

interface Testimonial {
  quote: string;
  author: string;
  role: string;
  stars: number;
}

interface Props {
  title: string;
  testimonials: Testimonial[];
}

const { title, testimonials } = Astro.props;
---

<section id="testimonios" class="bg-bg py-24 md:py-32 border-t border-border">
  <div class="px-4 md:px-8 lg:px-16 xl:px-24 max-w-7xl mx-auto">
    <SectionHeader title={title} align="left" />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-0 border-l border-t border-border-light mt-16">
      {
        testimonials.map((testimonial) => (
          <div class="bg-surface border-r border-b border-border-light p-10 flex flex-col h-full" data-animate="testimonial">
            <div class="mb-6 font-display text-6xl text-border-light leading-none">
              "
            </div>

            <p class="text-text-muted mb-8 italic leading-relaxed flex-grow">"{testimonial.quote}"</p>

            <div class="mt-auto">
              <div class="mb-4">
                <StarRating count={testimonial.stars} />
              </div>
              <p class="font-display font-semibold text-text text-lg">{testimonial.author}</p>
              <p class="label-caps text-text-muted mt-2">{testimonial.role}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReduced) {
    gsap.from('[data-animate="testimonial"]', {
      opacity: 0,
      y: 20,
      duration: 0.8,
      stagger: 0.15,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '#testimonios .grid',
        start: 'top 85%',
        once: true,
      },
    });
  }
</script>
