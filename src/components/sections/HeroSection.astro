---
import Button from '../ui/Button.astro';
import AmbientBackground from '../ui/AmbientBackground';

interface Props {
  headline: string;
  subheadline: string;
  image: string;
  ctaPrimary: string;
  ctaSecondary: string;
  trust: string[];
}

const { headline, subheadline, image, ctaPrimary, ctaSecondary, trust } = Astro.props;
---

<section class="relative min-h-screen flex items-center justify-center pt-20 overflow-hidden">
  <AmbientBackground client:only="react" />

  <div class="absolute inset-0 z-[1]" style="background: var(--hero-gradient);"></div>
  <div class="absolute bottom-0 inset-x-0 h-32 z-[1]" style="background: linear-gradient(to bottom, transparent, var(--color-bg));"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 md:px-8 lg:px-16 xl:px-24 py-16 md:py-24">
    <div
      class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-primary/30 bg-primary/8 text-primary text-xs font-semibold tracking-widest uppercase mb-6"
      data-animate="badge"
    >
      Kinesiología · Rehabilitación
    </div>

    <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold text-text mb-6 leading-tight" data-animate="headline">
      Recuperá tu <span class="hero-gradient-text">movimiento</span>, recuperá tu vida
    </h1>

    <p class="text-lg md:text-xl text-text-muted/90 mb-10 max-w-xl leading-relaxed" data-animate="subheadline">
      {subheadline}
    </p>

    <div class="flex flex-col sm:flex-row gap-5 mb-12" data-animate="ctas">
      <Button variant="secondary" size="lg" text={ctaPrimary} onClick="document.getElementById('calendar')?.scrollIntoView({behavior:'smooth'})" data-magnetic class="shadow-md" />
      <Button variant="ghost" size="lg" text={ctaSecondary + ' →'} onClick="document.getElementById('servicios')?.scrollIntoView({behavior:'smooth'})" class="text-primary border-primary hover:bg-primary/10" />
    </div>

    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 text-text-muted text-sm mt-10" data-animate="trust">
      {
        trust.map((item, index) => (
          <>
            <span>{item.replace('✓', '')}</span>
            <span class="text-success">{item.includes('✓') ? '✓' : ''}</span>
            {index < trust.length - 1 && <span class="hidden sm:inline text-border">·</span>}
          </>
        ))
      }
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-[2]" data-animate="scroll-hint">
      <div class="scroll-indicator">↓</div>
    </div>
  </div>
</section>

<style>
  section {
    background-attachment: fixed;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { splitAndReveal } from '@/lib/animations';

  document.addEventListener('DOMContentLoaded', () => {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return;

    const badge = document.querySelector('[data-animate="badge"]');
    const headline = document.querySelector('[data-animate="headline"]');
    const subheadline = document.querySelector('[data-animate="subheadline"]');
    const ctas = document.querySelector('[data-animate="ctas"]');
    const trust = document.querySelector('[data-animate="trust"]');
    const scrollHint = document.querySelector('[data-animate="scroll-hint"]');

    const tl = gsap.timeline({ delay: 0.15 });

    // Badge: fade in first
    if (badge) {
      tl.from(badge, { opacity: 0, y: -12, duration: 0.6, ease: 'power2.out' }, 0);
    }

    // Headline: words slide up one by one
    if (headline) splitAndReveal(headline, { delay: 0.2 });

    // Subheadline: fade up + blur focus
    if (subheadline) {
      tl.from(subheadline, {
        y: 25, opacity: 0, duration: 0.7, ease: 'power2.out',
        filter: 'blur(6px)',
        onStart: () => { subheadline.style.filter = 'blur(6px)'; },
        onComplete: () => { subheadline.style.filter = 'blur(0px)'; }
      }, 0.5);
    }

    // CTA buttons: scale + fade
    if (ctas) {
      tl.from(ctas.children, {
        y: 20, opacity: 0, scale: 0.95, duration: 0.6, stagger: 0.12, ease: 'back.out(1.2)',
      }, 0.8);
    }

    // Trust bar items: fade in staggered
    if (trust) {
      tl.from(trust.children, {
        opacity: 0, y: 10, duration: 0.4, stagger: 0.08,
      }, 1.1);
    }

    // Scroll indicator: fade in last, then loop with CSS
    if (scrollHint) {
      tl.from(scrollHint, { opacity: 0, y: -8, duration: 0.5 }, 1.5);
    }
  });
</script>
