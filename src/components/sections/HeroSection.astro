---
import Button from '../ui/Button.astro';

interface Props {
  headline: string;
  subheadline: string;
  trust: string;
  ctaPrimary: string;
}

const { headline, subheadline, trust, ctaPrimary } = Astro.props;

// Helper to format headline into multiple spans (last 2 are italic)
const lines = headline.split('\n');
const firstLine = lines[0] || '';
const italicLines = lines.slice(1);
---

<!-- Scroll proxy — creates the scroll range for the camera animation to glide inside the room -->
<div id="hero-scroll-proxy" class="relative">

  <!-- Sticky container — pins the text while scroll proxy scrolls -->
  <div class="sticky top-0 min-h-screen flex items-center justify-center pt-20 overflow-hidden bg-transparent">
    <div class="relative z-10 w-full max-w-7xl mx-auto px-4 md:px-8 lg:px-16 xl:px-24 py-16 md:py-24 grid grid-cols-1 md:grid-cols-12 gap-12 items-center border-b border-border min-h-screen">

      <!-- Text column with subtle scrim gradient for readability over 3D -->
      <div class="md:col-span-7 flex flex-col items-start justify-center relative z-20">
        <!-- Scrim background just behind the text for readability -->
        <div class="absolute inset-0 -ml-12 -mr-12 md:-mr-32 -my-24 pointer-events-none" style="background: linear-gradient(to right, rgba(245,240,232,1) 0%, rgba(245,240,232,0.85) 60%, rgba(245,240,232,0) 100%);"></div>
        
        <div class="overflow-hidden mb-8 w-full relative z-10">
          <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-[5rem] xl:text-[5.5rem] font-display text-text leading-[0.95] tracking-tight" data-animate="headline">
            {firstLine}
            {italicLines.map(line => (
              <span class="block italic font-light">{line}</span>
            ))}
          </h1>
        </div>

        <div class="overflow-hidden mb-6 relative z-10">
          <p class="text-lg md:text-xl text-text-muted max-w-xl leading-relaxed font-medium drop-shadow-sm" data-animate="subheadline">
            {subheadline}
          </p>
        </div>

        <div class="overflow-hidden mb-12 relative z-10">
          <div class="label-caps text-text-muted font-bold tracking-wider" data-animate="trust">
            {trust}
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-6 mb-16 overflow-hidden relative z-10" data-animate="ctas">
          <Button variant="primary" size="lg" text={ctaPrimary} onClick="document.getElementById('calendar')?.scrollIntoView({behavior:'smooth'})" />
        </div>
      </div>

      <!-- Empty right column to let 3D background show through -->
      <div class="md:col-span-5 relative hidden md:block">
      </div>

      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-[2] overflow-hidden" data-animate="scroll-hint">
        <div class="scroll-indicator">↓</div>
      </div>
    </div>
  </div>

</div>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return;

    const headline = document.querySelector('[data-animate="headline"]');
    const subheadline = document.querySelector('[data-animate="subheadline"]');
    const trust = document.querySelector('[data-animate="trust"]');
    const ctas = document.querySelector('[data-animate="ctas"]');
    const scrollHint = document.querySelector('[data-animate="scroll-hint"]');

    const tl = gsap.timeline({ delay: 0.2 });

    if (headline) {
      tl.from(headline, { clipPath: 'inset(100% 0 0 0)', y: 40, duration: 1.2, ease: 'power3.out' }, 0);
    }

    if (subheadline) {
      tl.from(subheadline, {
        clipPath: 'inset(100% 0 0 0)', y: 30, duration: 1, ease: 'power3.out'
      }, 0.2);
    }

    if (trust) {
      tl.from(trust, {
        opacity: 0, duration: 0.8, ease: 'power2.out',
      }, 0.5);
    }

    if (ctas) {
      tl.from(ctas.children, {
        y: '100%', opacity: 0, duration: 0.8, stagger: 0.15, ease: 'power3.out',
      }, 0.7);
    }

    if (scrollHint) {
      tl.from(scrollHint, { opacity: 0, duration: 1 }, 1.2);
    }
  });
</script>
