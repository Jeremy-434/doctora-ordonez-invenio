---
import { siteConfig } from '../config/site';
import BaseLayout from '../components/layout/BaseLayout.astro';
import HeaderSection from '../components/sections/HeaderSection.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import TrustSection from '../components/sections/TrustSection.astro';
import ServicesSection from '../components/sections/ServicesSection.astro';
import ProcessSection from '../components/sections/ProcessSection.astro';
import InfrastructureSection from '../components/sections/InfrastructureSection.astro';
import EducationalSection from '../components/sections/EducationalSection.astro';
import TeamSection from '../components/sections/TeamSection.astro';
import TestimonialsSection from '../components/sections/TestimonialsSection.astro';
import LoyaltySection from '../components/sections/LoyaltySection.astro';
import FAQSection from '../components/sections/FAQSection.astro';
import ContactSection from '../components/sections/ContactSection.astro';
import CalendarSection from '../components/sections/CalendarSection.astro';
import FooterSection from '../components/sections/FooterSection.astro';
---

<BaseLayout
  title={siteConfig.seo.title}
  description={siteConfig.seo.description}
  ogImage={siteConfig.seo.ogImage}
>
  <HeaderSection logo={siteConfig.brand.logo} navLinks={siteConfig.footer.navLinks} />

  <HeroSection
    headline={siteConfig.hero.headline}
    subheadline={siteConfig.hero.subheadline}
    trust={siteConfig.hero.trust}
    ctaPrimary={siteConfig.hero.ctaPrimary}
  />

  <TrustSection trustIndicators={siteConfig.trustIndicators} />

  <ServicesSection services={siteConfig.services} />

  <ProcessSection
    title={siteConfig.process.title}
    subtitle={siteConfig.process.subtitle}
    steps={siteConfig.process.steps}
  />

  <InfrastructureSection infrastructure={siteConfig.infrastructure} />

  <EducationalSection educational={siteConfig.educational} />

  <TeamSection team={siteConfig.team} />

  <TestimonialsSection title={siteConfig.testimonials.title} testimonials={siteConfig.testimonials.items} />

  <LoyaltySection loyalty={siteConfig.loyalty} />

  <FAQSection faq={siteConfig.faq} />

  <ContactSection contact={siteConfig.contact} whatsapp={siteConfig.whatsapp} />

  <CalendarSection calendarId={siteConfig.ghlCalendarId} baseUrl={siteConfig.calendarBaseUrl} />

  <FooterSection
    logo={siteConfig.brand.logo}
    tagline={siteConfig.footer.tagline}
    navLinks={siteConfig.footer.navLinks}
    copyright={siteConfig.footer.copyright}
  />
</BaseLayout>
